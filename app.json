    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00AACC"
      },
      "package": "com.securesync.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "841ce2f1-8faa-4091-a4da-2d482e6dd22a"
      }
    }
  }
}
