# =============================================================
# SecureSync — Environment Variables Template
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit your .env file to version control
# =============================================================

# -------------------------------------------------------------
# Application
# -------------------------------------------------------------
NODE_ENV=development                        # development | staging | production
APP_PORT=3000
APP_VERSION=1.0.0
WORKSPACE_ID=your_workspace_uuid           # UUID for multi-tenancy

# -------------------------------------------------------------
# PostgreSQL Database
# -------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=securesync
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_SSL=false                         # Set to true in production
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/securesync

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password         # Leave empty if no auth
REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------
# JWT Authentication
# -------------------------------------------------------------
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRY=15m                             # Access token — 15 minutes
REFRESH_TOKEN_SECRET=your_refresh_token_secret_minimum_32_characters
REFRESH_TOKEN_EXPIRY=30d                   # Refresh token — 30 days
BIOMETRIC_TOKEN_EXPIRY=60s                 # Biometric re-auth token — 60 seconds

# -------------------------------------------------------------
# File Storage — AWS S3
# -------------------------------------------------------------
STORAGE_PROVIDER=aws                       # aws | azure
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_BUCKET_NAME=securesync-files
AWS_REGION=eu-west-1                       # EU region for GDPR compliance
AWS_PRESIGNED_URL_EXPIRY=3600              # Pre-signed URL expiry in seconds

# -------------------------------------------------------------
# File Storage — Azure Blob (alternative to AWS S3)
# -------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_CONTAINER_NAME=securesync-files
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# -------------------------------------------------------------
# Push Notifications — Firebase Cloud Messaging (Android)
# -------------------------------------------------------------
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account.json

# -------------------------------------------------------------
# Push Notifications — APNs (iOS)
# -------------------------------------------------------------
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_KEY_PATH=./config/apns-auth-key.p8
APNS_BUNDLE_ID=com.yourcompany.securesync
APNS_PRODUCTION=false                      # Set to true for App Store builds

# -------------------------------------------------------------
# WebSocket (Chat Service)
# -------------------------------------------------------------
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000               # 30 seconds
WS_MAX_CONNECTIONS=1000

# -------------------------------------------------------------
# Auth Service
# -------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:3000
AUTH_SERVICE_PORT=3000
BCRYPT_SALT_ROUNDS=12

# -------------------------------------------------------------
# Chat Service
# -------------------------------------------------------------
CHAT_SERVICE_URL=http://localhost:3001
CHAT_SERVICE_PORT=3001
MAX_MESSAGE_LENGTH=4096
MESSAGE_HISTORY_LIMIT=100

# -------------------------------------------------------------
# File Service
# -------------------------------------------------------------
FILE_SERVICE_URL=http://localhost:3002
FILE_SERVICE_PORT=3002
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,mp4,mov
ZERO_GALLERY_ENFORCED=true                 # Must always be true

# -------------------------------------------------------------
# Tag Service
# -------------------------------------------------------------
TAG_SERVICE_URL=http://localhost:3003
TAG_SERVICE_PORT=3003
MANDATORY_TAG_ENFORCED=true               # Must always be true

# -------------------------------------------------------------
# Admin Service
# -------------------------------------------------------------
ADMIN_SERVICE_URL=http://localhost:3004
ADMIN_SERVICE_PORT=3004
ADMIN_AUDIT_LOG_RETENTION_DAYS=365

# -------------------------------------------------------------
# Security
# -------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000               # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
HELMET_ENABLED=true
ENCRYPTION_KEY=your_32_character_encryption_key_here

# -------------------------------------------------------------
# Monitoring & Logging
# -------------------------------------------------------------
LOG_LEVEL=info                            # error | warn | info | debug
LOG_FORMAT=json                           # json | pretty
SENTRY_DSN=your_sentry_dsn               # Optional — error tracking

# -------------------------------------------------------------
# Terraform / Infrastructure
# -------------------------------------------------------------
TF_VAR_environment=development
TF_VAR_region=eu-west-1
TF_VAR_project_name=securesync
